# -*- coding: utf-8 -*-
# 环境变量配置示例
# 复制此文件为 .env 并修改配置值

# ============ 应用配置 ============
# 应用名称
APP_NAME=FastAPI Application
# 应用环境: development, testing, production
APP_ENV=development
# 调试模式
DEBUG=True
# 服务主机
HOST=0.0.0.0
# 服务端口
PORT=8000

# ============ 数据库配置 ============
# 数据库类型: mysql, postgresql
DATABASE_TYPE=mysql
# 数据库主机
DATABASE_HOST=127.0.0.1
# 数据库端口
DATABASE_PORT=3306
# 数据库名称
DATABASE_NAME=fastapi_db
# 数据库用户名
DATABASE_USER=root
# 数据库密码
DATABASE_PASSWORD=123456
# 数据库连接池大小
DATABASE_POOL_SIZE=10
# 数据库连接池最大溢出
DATABASE_MAX_OVERFLOW=20
# 数据库连接超时时间（秒）
DATABASE_POOL_TIMEOUT=30
# 是否开启 SQL 日志输出
DATABASE_ECHO=True

# ============ JWT 配置 ============
# JWT 密钥（生产环境请使用强随机密钥）
JWT_SECRET_KEY=your-secret-key-change-in-production-please
# JWT 算法
JWT_ALGORITHM=HS256
# JWT 过期时间（分钟）
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ============ Redis 配置（可选） ============
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# ============ 日志配置 ============
# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# 日志文件路径
LOG_FILE_PATH=logs/app.log
